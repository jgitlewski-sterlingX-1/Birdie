# Relay API Server
RELAY_API_PORT=8787

# Google OAuth (Web application client created in rocketclicks.com GCP org)
GMAIL_CLIENT_ID=your-google-client-id
GMAIL_CLIENT_SECRET=your-google-client-secret
GMAIL_REDIRECT_URI=https://relay.sterlingx.com/api/integrations/gmail/callback

# Multi-Domain Configuration
# Comma-separated list of authorized email domains
ALLOWED_DOMAINS=rocketclicks.com,sterlinglawyers.com

# Public URL for CORS and redirects
RELAY_PUBLIC_URL=https://relay.sterlingx.com
FRONTEND_URL=http://localhost:5176

# CORS Origins (comma-separated)
# Prod: https://relay.sterlingx.com, Dev: http://localhost:5174
ALLOWED_ORIGINS=https://relay.sterlingx.com,http://localhost:5174

# Database Connection (to be configured for production)
# DATABASE_URL=postgresql://user:password@db.rocketclicks.com:5432/relay_prod

# Optional: Gmail Integration
# GMAIL_SYNC_ENABLED=false

# Frontend API base URL (set in frontend hosting env for production)
# Example: VITE_API_BASE_URL=https://relay-api-rccckcuv7a-uc.a.run.app
# Leave empty for local dev with Vite proxy.
# VITE_API_BASE_URL=
