# =============================================================================
# Relay API — environment config TEMPLATE
# Copy to the target environment's .env and fill in the two secrets.
#   - Local dev:  relay/kanban/.env
#   - Production: ~/relay-api/relay/kanban/.env  (on the Cloudways server)
# The real .env is gitignored — never commit filled-in credentials.
# =============================================================================

# -----------------------------------------------------------------------------
# CREDENTIALS  <- update these when rotating the Google OAuth client
# -----------------------------------------------------------------------------
GMAIL_CLIENT_ID=__FILL_IN__
GMAIL_CLIENT_SECRET=__FILL_IN__

# Claude (email reply drafting + triage). Server-side only — never VITE_-prefixed.
ANTHROPIC_API_KEY=__FILL_IN__

# Slack OAuth (read + send as the user). Client ID/Secret from the Slack app's
# Basic Information -> App Credentials. Slack requires an HTTPS redirect URL.
SLACK_CLIENT_ID=__FILL_IN__
SLACK_CLIENT_SECRET=__FILL_IN__

# Feature-flag admin bootstrap: comma-separated emails granted the admin role
# (manage flags + assign user roles). Flags/roles persist in MySQL.
ADMIN_EMAILS=__FILL_IN__

# -----------------------------------------------------------------------------
# ACCESS CONTROL  <- email domains allowed to sign in (comma-separated)
# -----------------------------------------------------------------------------
ALLOWED_DOMAINS=rocketclicks.com,sterlinglawyers.com

# -----------------------------------------------------------------------------
# ENVIRONMENT URLS
# GMAIL_REDIRECT_URI must be registered in Google Cloud Console under the
# OAuth client's "Authorized redirect URIs".
#
# Production (Cloudways):
#   RELAY_API_PORT=8787
#   GMAIL_REDIRECT_URI=https://phpstack-1565248-6494558.cloudwaysapps.com/api/auth/callback
#   FRONTEND_URL=https://phpstack-1565248-6494558.cloudwaysapps.com
#   ALLOWED_ORIGINS=https://phpstack-1565248-6494558.cloudwaysapps.com
#
# Local dev:
#   RELAY_API_PORT=8787
#   GMAIL_REDIRECT_URI=http://localhost:8787/api/auth/callback
#   FRONTEND_URL=http://localhost:5173
#   ALLOWED_ORIGINS=http://localhost:5173
# -----------------------------------------------------------------------------
RELAY_API_PORT=8787
GMAIL_REDIRECT_URI=https://phpstack-1565248-6494558.cloudwaysapps.com/api/auth/callback
FRONTEND_URL=https://phpstack-1565248-6494558.cloudwaysapps.com
ALLOWED_ORIGINS=https://phpstack-1565248-6494558.cloudwaysapps.com

# Slack OAuth callback. Must be registered verbatim in the Slack app's
# OAuth & Permissions -> Redirect URLs. HTTPS is required by Slack.
#   Production: https://phpstack-1565248-6494558.cloudwaysapps.com/api/integrations/slack/callback
#   Local dev:  needs an HTTPS tunnel (e.g. ngrok) — Slack rejects http://localhost.
SLACK_REDIRECT_URI=https://phpstack-1565248-6494558.cloudwaysapps.com/api/integrations/slack/callback
