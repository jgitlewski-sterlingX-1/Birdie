# Production env for the Relay API on the Cloudways server.
# Copy to ~/relay-api/relay/kanban/.env and fill in the two secrets.
# Do NOT commit the filled-in version.

# Google OAuth client (you said you have these)
GMAIL_CLIENT_ID=__FILL_IN__
GMAIL_CLIENT_SECRET=__FILL_IN__

# OAuth redirect — MUST be added verbatim as an Authorized redirect URI
# in the Google Cloud Console for this OAuth client.
GMAIL_REDIRECT_URI=https://phpstack-1565248-6494558.cloudwaysapps.com/api/auth/callback

# Where the server sends the browser back to after a successful login.
FRONTEND_URL=https://phpstack-1565248-6494558.cloudwaysapps.com

# CORS allow-list (same-origin in prod, so just the public domain).
ALLOWED_ORIGINS=https://phpstack-1565248-6494558.cloudwaysapps.com

# Domains permitted to sign in.
ALLOWED_DOMAINS=rocketclicks.com,sterlinglawyers.com

# Local port the Node API listens on; Nginx reverse-proxies /api to this.
RELAY_API_PORT=8787
